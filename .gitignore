# requirements.txt is generated by pip-compile during the image build.
# It is a build artifact — do not commit. Edit requirements.in instead.
requirements.txt

# =============================================================================
# Locale compiled output
# =============================================================================
# .mo files are compiled from .po sources by 'make langs'. Only .po files
# belong in the repo; .mo files are regenerated at build time.
pwnagotchi/locale/**/*.mo

